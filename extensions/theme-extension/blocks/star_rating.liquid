<script>

/* =========================
  TABS
========================= */

document.addEventListener(
  'click',
  function(e){

    if(
      e.target.matches(
        '.ebix-history-tabs button'
      )
    ){

      document
      .querySelectorAll(
        '.ebix-history-tabs button'
      )
      .forEach(btn => {

        btn.classList.remove(
          'active'
        );

      });

      e.target.classList.add(
        'active'
      );

      document
      .querySelectorAll(
        '.ebix-tab-panel'
      )
      .forEach(panel => {

        panel.style.display =
          'none';

      });

      document.getElementById(
        'ebix-tab-' +
        e.target.dataset.tab
      ).style.display =
        'block';

    }

  }
);

/* =========================
  COPY
========================= */

document.addEventListener(
  'click',
  function(e){

    if(
      e.target.id ===
      'ebix-cpy-ref-code'
    ){

      navigator.clipboard.writeText(
        document.getElementById(
          'ebix-pro-ref-code'
        ).innerText
      );

      e.target.innerText =
        'Copied';

      setTimeout(() => {

        e.target.innerText =
          'Copy';

      },1500);

    }

    if(
      e.target.id ===
      'ebix-cpy-redeem-code'
    ){

      navigator.clipboard.writeText(
        document.getElementById(
          'ebix-redeem-coupon'
        ).innerText
      );

      e.target.innerText =
        'Copied';

      setTimeout(() => {

        e.target.innerText =
          'Copy';

      },1500);

    }

  }
);

/* =========================
  HISTORY
========================= */

function ebix_render_history(logs, referralHistory = []) {
  let html = '';

  logs.forEach((log, index) => {
    const isCredit = log.transaction_type === 'credit';
    const reason = log.reason || '';

    // Extract order ID from reason: "Order: EG177995333595231 (...)"
    const orderMatch = reason.match(/Order:\s*([\w]+)/);
    const orderId = orderMatch ? orderMatch[1] : null;

    // Format amount if available
    const amount = log.order_total_amount
      ? ' ($' + parseFloat(log.order_total_amount).toFixed(2) + ')'
      : '';

    // Check if reason contains "Referrer："
    const hasReferrer = reason.includes('Referrer');

    // Check if reason contains "Referral："
    const hasReferral = reason.includes('Referral');

    // Check if reason contains "Redeem"
    const isRedeem = reason.toLowerCase().includes('redeem');

    // Check if it's a welcome reward (no order_id, referral type)
    const isWelcome = !log.order_id && log.point_earning_type === 'referral';
    
    const isVisit = !log.order_id && log.point_earning_type === 'auto';
    const isCouponReward = log.point_earning_type === "coupon_reward";
    let label = '';

      let referralName = "";

      const match1 = reason.match(/Referral\s*\(New Member\)：(.+)$/);

      if (match1) {
          referralName = match1[1].trim();
      }


      if (isWelcome) {

          let email = '';

          const match = reason.match(/Referral\s+NO\.(REF\d+)/i);

          if (match) {
              const referralNo = match[1];

              const referral = referralHistory.find(
                  r => r.referral_no === referralNo
              );

              email = referral?.email || '';
          }

        if (index === 0) {
            label = 'Task: Welcome Reward';
        } else {
            label = email
                ? `Referral (${email})`
                : 'Referral';
        }

      } else if (isVisit) {
          label = 'Task: Visit Page';

      } else if (hasReferrer && orderId) {
          label = 'Referrer: Order ' + orderId + amount;

      } else if (hasReferral && orderId) {
          label = `Referral: Order ${orderId}${amount}${
              referralName ? ' - ' + referralName : ''
          }`;

      } else if (isRedeem && orderId) {
          label = 'Redeem: Order ' + orderId + amount;

      } else if (orderId) {
          label = 'Order: ' + orderId + amount;

      }else if (isCouponReward) {
          label = log.reason;
      } else {
          label = log.badge || reason || 'Reward Activity';
      }

    // Format date from unix timestamp → YYYY-MM-DD
    let dateStr = '';
    if (log.created_at) {
      const d = new Date(log.created_at * 1000);
      const yyyy = d.getFullYear();
      const mm = String(d.getMonth() + 1).padStart(2, '0');
      const dd = String(d.getDate()).padStart(2, '0');
      dateStr = `${yyyy}-${mm}-${dd}`;
    }

    html += `
      <div class="ebix-history-item">
        <div class="ebix-history-top">
          <h4>${label}</h4>
          <div class="${isCredit ? 'ebix-points-credit' : 'ebix-points-debit'}">
            ${isCredit ? '+' : '-'}${log.points} Pts
          </div>
        </div>
        <div class="ebix-history-date">${dateStr}</div>
      </div>
    `;
  });

  if (!html) {
    html = `<div class="ebix-history-item">No Transaction History found</div>`;
  }

  document.getElementById('ebix-history-list').innerHTML = html;
}

/* =========================
  RENDER TASKS
========================= */

function ebix_render_tasks(tasks){
  let html = '';
  
  const iconMap = {
    'Register': '🎁',
    'visit_page': '🔗',
    'first_order': '🛒',
    'add_order': '🔄'
  };

  tasks.forEach(item => {
    item.rules.forEach(rule => {
      const icon = iconMap[rule.attribute_operation] || '⭐';
      const isPassed = rule.is_rule_passed;
      
      let btnHtml = '';
      if (isPassed) {
        btnHtml = '<button class="ebix-task-status-done" disabled>✓ Completed</button>';
      }

      html += `
        <div class="ebix-task-card">
          <div class="ebix-task-left">
            <div class="ebix-task-icon">${icon}</div>
            <div class="ebix-task-info">
              <h4>${rule.task} <span class="ebix-task-award">+${item.award}</span></h4>
            </div>
          </div>
          ${btnHtml}
        </div>
      `;
    });
  });

  return html;
}

/* =========================
  UPDATE UI BASED ON LOGIN STATE
========================= */

function ebix_update_ui_state(isLoggedIn, data) {

  const hasTasks =
    data &&
    data.referral_rule &&
    data.referral_rule.length > 0;

  // Task tab
  if (isLoggedIn) {

    document.getElementById('ebix-referral-card').style.display = 'none';
    document.getElementById('reward_only').style.display = 'none';

    if (hasTasks) {
      document.getElementById('tasks-title').style.display = 'block';
      document.getElementById('tasks-title').textContent =
        'Complete tasks to earn points';

      document.getElementById('ebix-logged-in-tasks').style.display = 'block';
      document.getElementById('ebix-logged-in-tasks').innerHTML =
        ebix_render_tasks(data.referral_rule);

    } else {
      document.getElementById('tasks-title').style.display = 'none';
      document.getElementById('ebix-logged-in-tasks').style.display = 'none';
      document.getElementById('ebix-referral-card').style.display = 'block';
      document.getElementById('ebix-referral-card').innerHTML = `
          <div style="font-size:15px; font-weight:700; color:#111; margin-bottom:4px;">
              No Referral Tasks
          </div>
      `;
    }

  } else {

    document.getElementById('ebix-referral-card').style.display = 'block';
    document.getElementById('ebix-referral-input-container').style.display = 'none';
    document.getElementById('ebix-signup-container').style.display = 'block';

    document.getElementById('tasks-title').style.display = 'none';
    document.getElementById('reward_only').style.display = 'block';
    document.getElementById('ebix-logged-in-tasks').style.display = 'none';
  }

  // Refer tab
  if (isLoggedIn) {
    document.getElementById('ebix-referral-code-display').style.display = 'block';
    document.getElementById('ebix-refer-login-prompt').style.display = 'none';
  } else {
    document.getElementById('ebix-referral-code-display').style.display = 'none';
    document.getElementById('ebix-refer-login-prompt').style.display = 'block';
  }

  // Redeem tab
  if (isLoggedIn) {
    document.getElementById('ebix-redeem-login-prompt').style.display = 'none';
    document.getElementById('ebix-redeem-logged-in').style.display = 'block';
  } else {
    document.getElementById('ebix-redeem-login-prompt').style.display = 'block';
    document.getElementById('ebix-redeem-logged-in').style.display = 'none';
  }
}

/* =========================
  INITIALIZE UI STATE
========================= */

function ebix_init_ui_state(){
  const isLoggedIn = typeof ebix_Promotion !== 'undefined' && ebix_Promotion.CustomerId;
  
  // Set initial state before API call
  if (!isLoggedIn) {
    document.getElementById('ebix-referral-card').style.display = 'block';
    document.getElementById('ebix-referral-input-container').style.display = 'none';
    document.getElementById('ebix-signup-container').style.display = 'block';
    document.getElementById('tasks-title').style.display = 'none';
    document.getElementById('reward_only').style.display = 'block';
    document.getElementById('ebix-logged-in-tasks').style.display = 'none';
    
    document.getElementById('ebix-referral-code-display').style.display = 'none';
    document.getElementById('ebix-refer-login-prompt').style.display = 'block';
    
    document.getElementById('ebix-redeem-login-prompt').style.display = 'block';
    document.getElementById('ebix-redeem-logged-in').style.display = 'none';
  }
}

// Initialize on DOM ready
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', ebix_init_ui_state);
} else {
  ebix_init_ui_state();
}

</script>

