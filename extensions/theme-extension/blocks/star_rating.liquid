{%- style -%}

  .ebix-modal{
    display:none;
    position:fixed;
    top:0;
    left:0;
    width:100%;
    height:100%;
    background:rgba(0,0,0,0.5);
    z-index:9999;
    align-items:center;
    justify-content:center;
  }

  .ebix-modal.show{
    display:flex;
  }

  .ebix-modal-dialog{
    width:100%;
    max-width:540px;
    margin:20px;
  }

  .ebix-modal-header{
    background:#111111;
    color:#ffffff;
    text-align:center;
    position:relative;
    font-weight:700;
    letter-spacing:.5px;
    display: block;
    padding: 24px;
  }

  .ebix-modal-title{
    margin:0;
    font-size:15px;
    font-weight:800;
  }

  .ebix-modal-close{
    color:#ffffff;
    position:absolute;
    right:14px;
    top:5px;
    background:none;
    border:none;
    font-size:24px;
    cursor:pointer;
  }

  .ebix-modal-content{
    border-radius: 26px;
  overflow: hidden;
  background: #fff;
  min-height: 400px;
  height: 580px;          /* ← fixed total height */
  display: flex;
  flex-direction: column;
  }

  .ebix-modal-body{
   flex: 1;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  }

  /* =========================
      DASHBOARD
  ========================= */

  #ebix-loyalty-dashboard{
   font-family: Arial, Helvetica, sans-serif;
  background: #fff;
  display: flex;
  flex-direction: column;
  height: 100%;
  }

  .ebix-wallet-header{
    padding:20px 24px 10px;
    display:flex;
    justify-content:space-between;
    align-items:flex-start;
    gap:2px;
  }
  .wallet-title-row{
    display:flex;
    align-items:center;
    gap:14px;
    flex-wrap:wrap;
  }
  .wallet-label{
    margin:0;
    font-size:16px;
    font-weight:800;
    color:#111;
    line-height:1;
  }

  .wallet-tier{
    display:inline;
    align-items:center;
  }

  #ebix-tier{
      display:inline;
      align-items:center;
      justify-content:center;
      background:#f7e58b;
      color:#000;
      border-radius:999px;
      padding:6px 18px;
      font-size:11px;
      font-weight:700;
      line-height:1;
  }

  .wallet-value-card{
    text-align:right;
  }

  .wallet-value-card p{
    margin:0;
    color:#7d7d7d;
    font-size:11px;
  }

  .wallet-value-card h3{
    margin:6px 0 0;
    color:#1570ff;
    font-size:60px;
    line-height:1;
    font-weight:800;
  }

  .ebix-history-tabs{
    display:flex;
    border-bottom:1px solid #e7e7e7;
    margin-top:10px;
  }

  .ebix-history-tabs button{
    flex:1;
    background:none;
    border:none;
    padding:16px 10px;
    font-size:13px;
    color:#666;
    cursor:pointer;
    position:relative;
  }

  .ebix-history-tabs button.active{
    color:#1570ff;
    font-weight:700;
  }

  .ebix-history-tabs button.active:after{
    content:'';
    position:absolute;
    left:0;
    bottom:0;
    width:100%;
    height:3px;
    background:#1570ff;
  }

  .ebix-dashboard-content{
    padding: 22px;
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  }

  .ebix-section-title{
    font-size:15px;
    font-weight:800;
    color:#111;
    margin-bottom:14px;
  }

  /* =========================
      TASK CARD
  ========================= */

  .ebix-task-card{
    background:#f4f4f6;
    border-radius:14px;
    padding:16px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:14px;
  }

  .ebix-task-left{
    display:flex;
    align-items:center;
    gap:12px;
  }

  .ebix-task-icon{
    width:38px;
    height:38px;
    border-radius:50%;
    background:#fff;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:18px;
  }

  .ebix-task-info h4{
    margin:0;
    font-size:14px;
    color:#111;
    font-weight:700;
  }

  .ebix-task-info span{
    color:#1570ff;
    font-size:13px;
    font-weight:700;
  }

  .ebix-task-btn{
    border:1px solid #1570ff;
    background:#fff;
    color:#1570ff;
    border-radius:8px;
    padding:8px 18px;
    font-size:12px;
    font-weight:700;
    cursor:pointer;
  }

  .ebix-task-btn.completed{
    border:none;
    background:#ebfff2;
    color:#22a55a;
  }

  .ebix-task-btn.view-btn{
    border:1px solid #1570ff;
    background:#fff;
    color:#1570ff;
    border-radius:8px;
    padding:8px 18px;
    font-size:12px;
    font-weight:700;
    cursor:pointer;
  }

  .ebix-task-btn.order-btn{
    border:1px solid #1570ff;
    background:#fff;
    color:#1570ff;
    border-radius:8px;
    padding:8px 18px;
    font-size:12px;
    font-weight:700;
    cursor:pointer;
  }

  /* =========================
      REFERRAL BOX
  ========================= */

  .ebix-referral-box{
    border:1px dashed #4ea0ff;
    background:#f8fbff;
    border-radius:16px;
    padding:18px;
    text-align:left;
  }

  .ebix-ref-top{
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:20px;
    flex-wrap:nowrap;
  }

  .ebix-referral-code-label{
    color:#1570ff;
    font-size:11px;
    font-weight:800;
    margin-bottom:8px;
  }

  .ebix-referral-code{
    font-size:24px;
    font-weight:900;
    color:#111;
    letter-spacing:1px;
  }

  .ebix-referral-code-small{
    font-size:18px;
    font-weight:800;
  }

  .ebix-ref-right{
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:10px;
}

.ebix-copy-btn{
  border:none;
  background:#111;
  color:#fff;
  border-radius:6px;
  padding:8px 16px;
  cursor:pointer;
  font-size:11px;
  margin:10px;
}

.ebix-quick-share-label{
  font-size:10px;
  font-weight:700;
  color:#666;
  text-transform:uppercase;
  margin-top:2px;
}

 .ebix-share-icons{
  display:flex;
  align-items:center;
  gap:8px;
}

 .ebix-share-icons a,
.ebix-share-icons span{
  width:32px;
  height:32px;
  border-radius:50%;
  background:#fff;
  border:1px solid #ddd;
  display:flex;
  align-items:center;
  justify-content:center;
  cursor:pointer;
  text-decoration:none;
  color:#111;
}

  /* =========================
      REDEEM
  ========================= */

  .ebix-redeem-main-btn{
    width:100%;
    border:none;
    background:#111;
    color:#fff;
    border-radius:10px;
    padding:15px;
    font-size:14px;
    font-weight:800;
    cursor:pointer;
  }

  .ebix-redeem-note{
    text-align:center;
    margin-top:16px;
    color:#777;
    font-size:12px;
    line-height:2;
  }

  .ebix-login-prompt{
    text-align:center;
  }

  .ebix-login-prompt p{
    color:#666;
    font-size:13px;
    margin:0 0 20px 0;
  }

  .ebix-login-btn{
    background:#111;
    color:#fff;
    border:none;
    border-radius:8px;
    padding:12px 24px;
    font-size:13px;
    font-weight:700;
    cursor:pointer;
  }

  .ebix-coupon-box{
    margin-top:18px;
    border:1px dashed #4ea0ff;
    background:#f8fbff;
    border-radius:14px;
    padding:16px;
    display:flex;
    justify-content:space-between;
    align-items:center;
  }

  .ebix-max-note{
    margin-top:12px;
    text-align:center;
    font-size:12px;
    color:#666;
  }

  /* =========================
      HISTORY
  ========================= */

  #ebix-history-list{
    display:flex;
    flex-direction:column;
    gap:14px;
  }

  .ebix-history-item{
    border:1px solid #ececec;
    border-radius:14px;
    padding:14px;
  }

  .ebix-history-top{
    display:flex;
    justify-content:space-between;
    gap:10px;
  }

  .ebix-history-top h4{
    margin:0;
    font-size:13px;
    color:#111;
  }

  .ebix-points-credit{
    color:#1570ff;
    font-weight:800;
    font-size:13px;
  }

  .ebix-points-debit{
    color:#ff4d4f;
    font-weight:800;
    font-size:13px;
  }

  .ebix-history-date{
    margin-top:8px;
    color:#888;
    font-size:11px;
    text-transform:lowercase;
  }
/* TASK CARDS */
